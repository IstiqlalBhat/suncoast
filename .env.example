# FieldFlow App Runtime Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Run the app with:
#   flutter run --dart-define-from-file=.env
# or build with:
#   flutter build <target> --dart-define-from-file=.env

# App environment label (development, staging, production)
APP_ENV=development

# Supabase (Dashboard > Settings > API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Firebase Cloud Functions (Firebase Console > Functions, after deploy)
FIREBASE_FUNCTIONS_URL=https://us-central1-your-project-id.cloudfunctions.net

# ---------------------------------------------------------------
# The following secrets are NOT used by the Flutter app.
# They must be set as Firebase Functions secrets via:
#   firebase functions:secrets:set SECRET_NAME
#
# GEMINI_API_KEY        - Google AI Studio API key for Gemini
# OPENAI_API_KEY        - OpenAI API key for Whisper transcription
# ELEVENLABS_API_KEY    - ElevenLabs API key for premium TTS
# SUPABASE_URL          - Supabase project URL (for service-role access)
# SUPABASE_SERVICE_KEY  - Supabase service-role key (NOT the anon key)
# ---------------------------------------------------------------
