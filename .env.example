# FieldFlow App Runtime Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Run the app with:
#   flutter run --dart-define-from-file=.env
# or build with:
#   flutter build <target> --dart-define-from-file=.env

# App environment label (development, staging, production)
APP_ENV=development

# Supabase (Dashboard > Settings > API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Firebase Cloud Functions (Firebase Console > Functions, after deploy)
FIREBASE_FUNCTIONS_URL=https://us-central1-your-project-id.cloudfunctions.net
