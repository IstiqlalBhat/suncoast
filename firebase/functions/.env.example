# Firebase Functions - Local Development
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# These are used by the Firebase Emulator (firebase emulators:start)
# In production, use: firebase functions:secrets:set <KEY_NAME>

# Gemini AI (aistudio.google.com)
GEMINI_API_KEY=your-gemini-api-key

# Supabase (Dashboard > Settings > API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Deepgram (console.deepgram.com)
DEEPGRAM_API_KEY=your-deepgram-api-key

# ElevenLabs (elevenlabs.io) — optional, for premium TTS
ELEVENLABS_API_KEY=your-elevenlabs-api-key
